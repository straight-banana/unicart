{
  "manifest_version": 3,
  "name": "Add To Cart Detector",
  "version": "1.0",
  "description": "Detects when Add to Cart is clicked",

  "action": {
    "default_popup": "extention.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detector.js"]
    }
  ]
}
